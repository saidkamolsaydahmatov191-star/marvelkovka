import { motion, useScroll, useTransform } from 'motion/react';
import { useRef } from 'react';
import React, { ReactNode } from 'react';
import { PRODUCTS } from '../constants';

export default function Reshotka3D() {
  const containerRef = useRef<HTMLDivElement>(null);
  const { scrollXProgress } = useScroll({
    container: containerRef,
  });

  const reshotkaProducts = PRODUCTS.filter(p => p.category === 'reshotka' || p.category === 'railings');

  return (
    <section id="reshotka" className="py-24 bg-dark overflow-hidden">
      <div className="max-w-7xl mx-auto px-12 mb-16">
        <motion.div
          initial={{ opacity: 0, x: -30 }}
          whileInView={{ opacity: 1, x: 0 }}
          transition={{ duration: 0.6 }}
        >
          <span className="text-gold uppercase tracking-[0.3em] text-[10px] mb-4 block">Eksklyuziv Dizayn</span>
          <h2 className="text-5xl font-serif mb-4">3D <span className="text-gold font-bold">Reshotkalar</span></h2>
          <p className="text-white/40 max-w-xl font-light italic">
            Bizning reshotkalarimiz nafaqat uyingizni himoya qiladi, balki tashqi ko'rinishiga 3D hajmdagi nafosat bag'ishlaydi.
          </p>
        </motion.div>
      </div>

      <div 
        ref={containerRef}
        className="flex gap-12 overflow-x-auto pb-12 px-12 scrollbar-hide snap-x snap-mandatory"
      >
        {reshotkaProducts.map((product, index) => (
          <ReshotkaCard key={product.id} product={product} index={index} />
        ))}
        {/* Placeholder for extra space */}
        <div className="min-w-[300px] h-1" />
      </div>

      <style>{`
        .scrollbar-hide::-webkit-scrollbar {
          display: none;
        }
        .scrollbar-hide {
          -ms-overflow-style: none;
          scrollbar-width: none;
        }
      `}</style>
    </section>
  );
}


interface ReshotkaCardProps {
  product: any;
  index: number;
}

const ReshotkaCard: React.FC<ReshotkaCardProps> = ({ product, index }) => {
  // We'll use a local observer for each card to get its projection within the viewport
  return (
    <motion.div
      initial={{ opacity: 0, rotateY: 45, translateZ: -100 }}
      whileInView={{ opacity: 1, rotateY: 0, translateZ: 0 }}
      viewport={{ once: false, amount: 0.5 }}
      transition={{ duration: 0.8, ease: "easeOut" }}
      className="min-w-[400px] md:min-w-[600px] h-[400px] relative group snap-center perspective-1000"
    >
      <div className="absolute inset-0 bg-gold/5 border border-white/5 transform transition-transform duration-500 group-hover:scale-[1.02]" />
      
      <div className="w-full h-full p-4 overflow-hidden">
        <img
          src={product.image}
          alt={product.name}
          className="w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-700"
          referrerPolicy="no-referrer"
        />
      </div>

      <div className="absolute top-8 left-8">
        <span className="bg-gold text-dark px-3 py-1 text-[10px] uppercase font-bold tracking-widest">
          3D Model {index + 1}
        </span>
      </div>

      <div className="absolute bottom-8 left-8 right-8">
        <h3 className="text-3xl font-serif text-white mb-2 transform group-hover:-translate-y-2 transition-transform duration-300">
          {product.name}
        </h3>
        <div className="w-0 h-[2px] bg-gold group-hover:w-full transition-all duration-500 mb-2" />
        <p className="text-white/40 text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          Hajm va mustahkamlik uyg'unligi
        </p>
      </div>

      {/* Decorative Corner */}
      <div className="absolute top-0 right-0 w-16 h-16 pointer-events-none overflow-hidden">
        <div className="absolute top-0 right-0 w-full h-[1px] bg-gold/50" />
        <div className="absolute top-0 right-0 h-full w-[1px] bg-gold/50" />
      </div>
    </motion.div>
  );
}
